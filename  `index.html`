<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>كاشف الاحتيال المالي</title>
    <link rel="stylesheet" href="style.css">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
</head>
<body>
    <div class="container">
        <header>
            <h1><i class="fas fa-shield-alt"></i> كاشف الاحتيال المالي</h1>
            <p>تحقق من أمان الروابط قبل النقر عليها</p>
        </header>

        <div class="input-section">
            <div class="input-group">
                <input type="url" id="urlInput" placeholder="أدخل رابط الموقع هنا...">
                <button id="checkBtn">
                    <i class="fas fa-search"></i> فحص الرابط
                </button>
            </div>
        </div>

        <div id="loading" class="loading hidden">
            <div class="spinner"></div>
            <p>جاري الفحص...</p>
        </div>

        <div id="result" class="result hidden">
            <div class="result-icon" id="resultIcon"></div>
            <div class="result-content">
                <h2 id="resultTitle"></h2>
                <p id="resultMessage"></p>
                <div class="details" id="resultDetails"></div>
            </div>
        </div>

        <div class="stats">
            <div class="stat">
                <span id="safeCount">0</span>
                <small>آمن</small>
            </div>
            <div class="stat">
                <span id="riskyCount">0</span>
                <small>مشبوه</small>
            </div>
        </div>
    </div>

    <script src="script.js"></script>
</body>
</html>